# .env.example – environment variables for Hu Tao WhatsApp Bot
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# =====================================================================
# BOT BASICS
# =====================================================================

# Nama bot yang tampil di pesan-pesan tertentu
BOT_NAME="Hu Tao AI"

# Prefix command (default ! atau .)
PREFIX="!"
ALT_PREFIX="."

# Nomor WhatsApp owner (tanpa +, pakai format internasional, misal 628...)
OWNER_NUMBER="628123456789"

# Pemilik tambahan (opsional, pisahkan dengan koma)
OWNERS="628111111111,628222222222"

# Owner LID (opsional, untuk multi-device WhatsApp)
OWNER_LIDS=""

# Mode bot (public | self)
BOT_MODE="public"

# Timezone (opsional, default Asia/Jakarta)
TIMEZONE="Asia/Jakarta"

# =====================================================================
# DATABASE — MongoDB
# =====================================================================
# Gunakan MongoDB Atlas (gratis) atau MongoDB lokal
# Contoh Atlas:   mongodb+srv://user:pass@cluster0.mongodb.net/hutao
# Contoh lokal:   mongodb://localhost:27017/hutao

MONGODB_URI="mongodb://localhost:27017/hutao"

# SESSION STORE (auto | mongo | file)
SESSION_STORE="auto"

# Folder penyimpanan sesi jika menggunakan file-based storage
SESSIONS_DIR="sessions"

# Delay reconnect (ms) jika koneksi terputus
RECONNECT_DELAY_MS=5000

# Delay reconnect database (ms)
DB_RECONNECT_DELAY_MS=10000

# Interval flush database (ms)
DB_FLUSH_INTERVAL_MS=5000

# =====================================================================
# AI — GROQ (Prioritas Utama)
# =====================================================================
# Daftar dan dapatkan API key gratis di https://console.groq.com
# Model yang direkomendasikan: llama-3.3-70b-versatile

GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GROQ_MODEL="llama-3.3-70b-versatile"

# =====================================================================
# AI — GOOGLE GEMINI (Fallback)
# =====================================================================
# Daftar dan dapatkan API key gratis di https://aistudio.google.com
# Untuk multi-key, pisahkan dengan koma: KEY1,KEY2,KEY3
# Untuk multi-model, pisahkan dengan koma: model1,model2

GEMINI_ENABLED=true
GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GEMINI_API_KEYS="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GEMINI_MODELS="gemini-2.5-flash-lite,gemini-2.0-flash-lite"
GEMINI_MAX_KEYS_PER_MODEL=2

# =====================================================================
# LOGIN & CONNECTION
# =====================================================================
# Metode login: qr | pairing
LOGIN_METHOD="qr"

# Nomor telepon untuk pairing (tanpa +, hanya angka)
PAIRING_PHONE=""

# =====================================================================
# SERVER & PORT
# =====================================================================
# Port untuk Express server
PORT=3000

# URL publik (untuk Railway atau deployment ke cloud)
PUBLIC_URL=""

# Environment Railway (auto-filled saat deploy di Railway)
RAILWAY_ENVIRONMENT=""
RAILWAY_PROJECT_ID=""
RAILWAY_SERVICE_NAME=""
RAILWAY_PUBLIC_DOMAIN=""

# Aktifkan Express server (true | false)
EXPRESS_ENABLED=true

# =====================================================================
# MENU STYLE
# =====================================================================
# Pilihan: image | list | interactive | text | auto
# - image       : Menu dikirim sebagai gambar/banner dengan teks
# - list        : Menu dalam format daftar native WhatsApp
# - interactive : Menu dalam format tombol interaktif WhatsApp
# - text        : Menu dalam format teks biasa
# - auto        : Sistem otomatis memilih style terbaik

MENU_STYLE="image"

# Aktifkan menu interaktif (true | false)
MENU_INTERACTIVE=true

# Banner image untuk menu (path atau URL)
MENU_BANNER_IMAGE=""

# Thumbnail untuk menu (path atau URL)
MENU_THUMBNAIL=""

# Thumbnail URL alternatif
MENU_THUMBNAIL_URL=""

# Source URL (link repo atau info lainnya)
MENU_SOURCE_URL=""

# =====================================================================
# COOLDOWN & MEMORY
# =====================================================================
# Default cooldown untuk command (ms)
DEFAULT_COOLDOWN_MS=3000

# Cooldown untuk premium users (ms)
PREMIUM_COOLDOWN_MS=1000

# Jumlah maksimal pesan history yang disimpan per user/group
MAX_MEMORY_MESSAGES=10

# =====================================================================
# FITUR KHUSUS
# =====================================================================
# Antilink groups (pisahkan dengan koma jika lebih dari satu)
ANTILINK_GROUPS=""

# YouTube-DL API endpoint (opsional)
YTDL_API=""

# =====================================================================
# FEATURE TOGGLES (Opsional — Default bisa dikontrol lewat .setting)
# =====================================================================
# Fitur-fitur di bawah juga bisa diaktifkan/matikan per-grup lewat
# command .setting <fitur> on/off atau .fitur <fitur> on/off

# Fitur group memory (ON secara default)
# GROUP_MEMORY_DEFAULT=true

# =====================================================================
# ENVIRONMENT & DEBUG
# =====================================================================
# Node environment (development | production)
NODE_ENV="development"

# =====================================================================
# STORAGE PATHS (Opsional — override jika dibutuhkan)
# =====================================================================
# Path penyimpanan profile picture collection
PP_STORAGE_PATH="/tmp/hutao-pp-collection.json"

# Path penyimpanan reminder data
REMINDER_STORAGE="/tmp/hutao-reminders.json"

# .env.example – environment variables for Hu Tao WhatsApp Bot
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# =====================================================================
# BOT BASICS
# =====================================================================

# Nama bot yang tampil di pesan-pesan tertentu
BOT_NAME="Hu Tao AI"

# Prefix command (default ! atau .)
PREFIX="!"
ALT_PREFIX="."

# Nomor WhatsApp owner (tanpa +, pakai format internasional, misal 628...)
OWNER_NUMBER="628123456789"

# Timezone (opsional, default Asia/Jakarta)
TIMEZONE="Asia/Jakarta"

# =====================================================================
# DATABASE — MongoDB
# =====================================================================
# Gunakan MongoDB Atlas (gratis) atau MongoDB lokal
# Contoh Atlas:   mongodb+srv://user:pass@cluster0.mongodb.net/hutao
# Contoh lokal:   mongodb://localhost:27017/hutao

MONGODB_URI="mongodb://localhost:27017/hutao"

# =====================================================================
# AI — GROQ (Prioritas Utama)
# =====================================================================
# Daftar dan dapatkan API key gratis di https://console.groq.com
# Model yang direkomendasikan: llama-3.3-70b-versatile

GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GROQ_MODEL="llama-3.3-70b-versatile"

# =====================================================================
# AI — GOOGLE GEMINI (Fallback)
# =====================================================================
# Daftar dan dapatkan API key gratis di https://aistudio.google.com
# Untuk multi-key, pisahkan dengan koma: KEY1,KEY2,KEY3
# Untuk multi-model, pisahkan dengan koma: model1,model2

GEMINI_ENABLED=true
GEMINI_API_KEYS="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GEMINI_MODELS="gemini-2.5-flash-lite"

# =====================================================================
# AI — 9ROUTER (Opsional, OpenAI-Compatible Gateway)
# =====================================================================
# Jika kamu punya gateway OpenAI-compatible sendiri, bisa diisi di sini
# Biarkan kosong jika tidak digunakan

NINEROUTER_URL=""
NINEROUTER_KEY=""
NINEROUTER_MODEL=""

# =====================================================================
# MENU STYLE
# =====================================================================
# Pilihan: image | list | interactive | text
# - image       : Menu dikirim sebagai gambar/banner dengan teks
# - list        : Menu dalam format daftar native WhatsApp
# - interactive : Menu dalam format tombol interaktif WhatsApp
# - text        : Menu dalam format teks biasa

MENU_STYLE="image"

# =====================================================================
# FEATURE TOGGLES (Opsional — Default bisa dikontrol lewat .setting)
# =====================================================================
# Fitur-fitur di bawah juga bisa diaktifkan/matikan per-grup lewat
# command .setting <fitur> on/off atau .fitur <fitur> on/off

# Fitur group memory (ON secara default)
# GROUP_MEMORY_DEFAULT=true